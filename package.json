{
  "name": "tradeautopsy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:unit": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage && open coverage/index.html",
    "test:ci": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:install": "playwright install chromium firefox",
    "test:e2e:install:all": "playwright install --with-deps",
    "test:performance": "lighthouse-ci autorun",
    "test:load": "k6 run __tests__/load/scenarios/normal-load.k6.js",
    "test:security": "vitest run --config vitest.security.config.ts",
    "test:a11y": "playwright test --grep @accessibility",
    "test:visual": "playwright test --grep @visual",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:jest": "jest",
    "test:jest:watch": "jest --watch",
    "test:jest:coverage": "jest --coverage",
    "seed": "tsx scripts/seed-bogus-data.ts",
    "seed:500": "tsx scripts/seed-bogus-data.ts 500",
    "analyze": "ANALYZE=true next build",
    "optimize": "npm run lint && npm run build && npm run analyze"
  },
  "dependencies": {
    "@supabase/auth-helpers-nextjs": "^0.15.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.83.0",
    "@tanstack/react-table": "^8.21.3",
    "@upstash/ratelimit": "^1.2.1",
    "@upstash/redis": "^1.35.8",
    "@vercel/speed-insights": "^1.3.1",
    "@workos-inc/node": "^7.77.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.24",
    "ioredis": "^5.8.2",
    "jose": "^6.1.3",
    "jspdf": "^3.0.4",
    "jspdf-autotable": "^5.0.2",
    "kiteconnect": "^5.1.0",
    "lru-cache": "^10.4.3",
    "lucide-react": "^0.554.0",
    "next": "^15.5.6",
    "openai": "^6.10.0",
    "papaparse": "^5.5.3",
    "pino": "^8.21.0",
    "pino-pretty": "^10.3.1",
    "razorpay": "^2.9.6",
    "react": "^19.2.0",
    "react-calendar-heatmap": "^1.10.0",
    "react-dom": "^19.2.0",
    "react-error-boundary": "^4.1.2",
    "react-loading-skeleton": "^3.5.0",
    "react-window": "^2.2.3",
    "recharts": "^3.5.1",
    "swr": "^2.3.8",
    "use-debounce": "^10.0.6",
    "web-vitals": "^5.1.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.3.0",
    "@next/bundle-analyzer": "^16.0.10",
    "@playwright/test": "^1.48.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.0",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^2.1.8"
  },
  "optionalDependencies": {
    "bufferutil": "^4.1.0",
    "utf-8-validate": "^5.0.10"
  }
